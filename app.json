{
  "expo": {
    "name": "Payroll App",
    "slug": "payrollapp",
    "owner": "prismatechteam",
    "version": "1.0.0",
    "scheme": "payrollapp",
    "orientation": "portrait",
    "icon": "./assets/appicon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.payroll.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AiPayroll needs your location to verify attendance check-in location.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "AiPayroll needs your location to verify attendance check-in location.",
        "NSFaceIDUsageDescription": "This app uses Face ID to verify your identity for attendance check-in."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/appicon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.payroll.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "useNextNotificationsApi": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "payrollapp"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#ffffff",
      "androidMode": "default",
      "androidCollapsedTitle": "#{unread_notifications} new notifications"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1976D2",
          "mode": "production"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow AiPayroll to use your location for attendance check-in.",
          "locationWhenInUsePermission": "Allow AiPayroll to use your location for attendance check-in."
        }
      ],
      "expo-localization",
      "expo-local-authentication"
    ],
    "extra": {
      "environment": "development",
      "apiUrl": "https://localhost:7133",
      "eas": {
        "projectId": "f99348cf-2307-484a-9305-dd7beddc86d6"
      }
    }
  }
}
