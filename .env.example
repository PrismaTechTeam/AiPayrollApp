# Firebase – same project as web (copy values from AiPayrollWeb/.env.development)
# Rename/copy to .env and fill in. Restart Expo after changes.
#
# Required (same as web):
#   VITE_FIREBASE_* in web → EXPO_PUBLIC_FIREBASE_* here
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=

# Optional (from Firebase Console → Project settings → Your apps → Web app config):
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
